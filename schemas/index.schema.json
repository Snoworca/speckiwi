{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://speckiwi.dev/schemas/index.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "project", "documents"],
  "properties": {
    "schemaVersion": { "const": "speckiwi/index/v1" },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "language": { "type": "string", "minLength": 1 }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "agent": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "defaultWriteMode": { "enum": ["propose", "apply"] },
            "allowApply": { "type": "boolean" }
          }
        },
        "search": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "defaultMode": { "enum": ["auto", "exact", "bm25"] },
            "koreanNgram": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "min": { "type": "integer", "minimum": 1 },
                "max": { "type": "integer", "minimum": 1 }
              }
            }
          }
        }
      }
    },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "path"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "type": { "enum": ["overview", "prd", "srs", "technical", "adr", "rule", "dictionary", "prose"] },
          "path": { "type": "string", "minLength": 1 },
          "scope": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "scopes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "type"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "parent": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "type": {
            "enum": ["module", "submodule", "feature", "domain", "component", "package", "conceptual", "external_boundary"]
          },
          "description": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "to", "type"],
        "properties": {
          "from": { "type": "string", "minLength": 1 },
          "to": { "type": "string", "minLength": 1 },
          "type": { "enum": ["relates_to", "refines", "supersedes", "depends_on", "documents", "implements", "references"] },
          "description": { "type": "string" }
        }
      }
    }
  }
}
