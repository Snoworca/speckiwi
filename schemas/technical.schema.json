{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://speckiwi.dev/schemas/technical.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "id", "type", "title", "status", "sections"],
  "properties": {
    "schemaVersion": { "const": "speckiwi/technical/v1" },
    "id": { "type": "string", "minLength": 1 },
    "type": { "const": "technical" },
    "title": { "type": "string", "minLength": 1 },
    "status": { "enum": ["draft", "active", "deprecated", "archived"] },
    "scope": { "type": "string", "minLength": 1 },
    "implements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "body"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "body": { "type": "string" },
          "metadata": {
            "type": "object",
            "additionalProperties": true
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
